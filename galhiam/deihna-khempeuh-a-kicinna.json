{
  "title": "DEIHNA KHEMPEUH A KICINNA",
  "key": "Key: G",
  "galHiam": "Gal Hiam: 103",
  "ZBC": null,
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Deihna khempeuh a kicinna",
        "Lawmpha Zeisu nei ing",
        "Kei ading tulsawm tulthen sang hoih zaw hi",
        "Zangkuam unokpaak zah a hoih",
        "Amah bek ke'n mu ing",
        "Dam nang siannag kadeih teng",
        "A sung'h om hi",
        "Dah hun cianghong hehnem in",
        "Haksat ciang bukna hi",
        "Na vangik khempeuh hong puakin hong ci",
        "Hallelujah"
      ]
    },
    {
      "type": "chorus",
      "label": "Chorus",
      "lines": [
        "Amah zangkuam unok paak hi",
        "A taang zingsol zong hi",
        "Kei ading tulsawm tulthen sang hoih zaw hi"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Ka lungkhamna teng lakhia in",
        "Dahna hong puak sak a",
        "Ze-et hunciang a muanhuai katausang hi",
        "Upna siasak thei nakhempeuh",
        "Ke'n tu'n kanusia ta",
        "Ka sungpan a vangliatna tawh hong kem hi",
        "Leitungin kei hong nial in",
        "Satan in hong do hang",
        "Zeisu hangin kama ka tunding hi",
        "Hallelujah"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Amah'n hong nusia ngeilo ding",
        "Zong hong nial ngeilo ding",
        "Amah um in a deihna bang ta peuh leng",
        "Keitungah bang bang piang taleh",
        "lau nawn peuhmah kei ning",
        "Mana tawh kakha hong vakding nuamlua veng",
        "Minthang gamzuan in lengning",
        "Topa kamu ding hi",
        "Lungnopna guntui a luanna mun hi",
        "Hallelujah"
      ]
    }
  ]
}