{
  "title": "BEEL TAMPI HONG PAIPIH IN",
  "key": "Key: Eb",
  "galHiam": "Gal Hiam: 68",
  "ZBC": null,
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Na lungsung Topa'h thupha",
        "A dimtak ong piak nading in",
        "Na lunggulh hiam tu ni in",
        "Na pa' hong ciam na muang in la",
        "A hong cih bang hong pai in",
        "Taang misiangte' pai bang in"
      ]
    },
    {
      "type": "chorus",
      "label": "Chorus",
      "lines": [
        "Na lungsung dimlet dong",
        "Tuni'n hong buak ding hi",
        "Topa hong sawlna bang in",
        "Beel tampi hong paipih in",
        "Na lungsung dimlet dong",
        "Tuni'n hong buak ding hi",
        "Kha Siangtho vangliatna tawh"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Zeisu Sisan sianthosak san",
        "Na leibeel te hong keng in",
        "Hong pai un a sam dang zong",
        "Pasian tokhom mai ah",
        "Na pumpi kipia in la ngak in",
        "Kha Siangtho hong kibuak dong"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Sathau bei ngeilo bang in",
        "Hong hehpih na'n beihun nei lo",
        "Hong itna zong bei lo hi",
        "A hong ciam na sa bang in",
        "Kha Siangtho vanglian ki teh lo",
        "Beel khempeuh dimsak ding hi"
      ]
    }
  ]
}