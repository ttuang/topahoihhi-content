{
  "title": "A THU KA GENGEN NUAM HI",
  "key": "Key: Ab",
  "ZBC": "ZBC: 415",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "A thu ka gengen nuam hi,",
        "Muh nai-loh vantung na;",
        "Jesuh leh Ama vangpi,",
        "Jesuh leh",
        "hongit-na",
        "Thu ka gengen nuam hi,",
        "Thuman ahih manin;",
        "Ka lungsim hong kim sak hi,",
        "Thu",
        "dangte bang lo-in."
      ]
    },
    {
      "type": "chorus",
      "label": "Chorus",
      "lines": [
        "Tua thu ka gen-gen nuam hi,",
        "Gengen lai ning",
        "vantungah;",
        "Hih thu tul thei ngei lo pi,",
        "Jesuh le hong itna."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "A thu ka gengen nuam",
        "hi,",
        "Lamdang semsem ka sa;",
        "Kingaihsun thei nawn lopi,",
        "Tua sang lamdangzaw na;",
        "Tua thu ka",
        "gengen nuam hi, Hong nop-tuamsak na lian;",
        "Tua hang mah’n kong gen sawn hi, Tu in lawm aw, nang",
        "kiang."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "A thu ka gengen nuam hi,",
        "Gengen leng nuam semsem;",
        "Ka gengen sa hi",
        "napi,",
        "Gengen leng ngaih semsem;",
        "Tua thu ka gengen nuam hi,",
        "Hotkhiatna thu a pha;",
        "A za",
        "nai lo mi om hi,",
        "Pasian hong gen thupha."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "A thu ka gengen nuam hi,",
        "A thei pente",
        "in zong;",
        "An duh tuiduh bang duh hi,",
        "Midangte sang in zong;",
        "Vantung vanliatna sungah,",
        "La",
        "thak ka sa ding hi;",
        "Tua ciangin hih thului mah,",
        "Kei in ka sa ding hi."
      ]
    }
  ]
}