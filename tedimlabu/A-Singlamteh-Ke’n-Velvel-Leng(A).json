{
  "title": "125(A). A SINGLAMTEH KE’N VELVEL LENG",
  "key": "Key: Eb",
  "ZBC": null,
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Vanglian Kumpipa hong sihna,",
        "A singlamteh ke’n velvel leng",
        "Kei’ hauhna kei",
        "kiphat sakna,",
        "Ke’n tu’n bangmah in sim nawn keng"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Khazih ka Pasian sihna",
        "lo,",
        "Kisialhpih ding bangmah om kei;",
        "Ka deih bel teng khat zong siit lo,",
        "Ama’ si khekna",
        "in ka nei."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "En ven, a lu a khut, akhe,",
        "Dahna, itna hong luang suk khawm;",
        "Na mu",
        "ngei maw linglukhu le,",
        "Itna, dahna gawm kilawm khawm."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Leitung khempeuh pia thei",
        "hileng,",
        "Tamlua ka ci ngei kei ding hi;",
        "A hong itna ke’n ngaihsun leng,’",
        "Ka pum ka",
        "tak ka pia nuam hi."
      ]
    }
  ]
}