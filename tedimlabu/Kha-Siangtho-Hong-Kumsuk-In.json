{
  "title": "Kha Siangtho, Hong Kumsuk IN",
  "key": "Key: G",
  "ZBC": "ZBC: 177",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Kha Siangtho vakhu bangin ah,",
        "Hong pai in vanglian tawh;",
        "Na itna mei bang hong tawh",
        "in,",
        "A dai ko lungsung ah."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Kote lasak ngei bangin ah,",
        "Thoto-in sa",
        "zolo;",
        "Hosanna ci’n ko aw ging lo,",
        "Kote biakna sita."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Topa tua bang ko si",
        "ding maw,",
        "Hehpih huai mahmah ung;",
        "Ka hong itna uh a neu hang,",
        "Nang nong itna",
        "lianzaw."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Kha Siangtho vakhu bangin ah,",
        "Hong pai in vanglian tawh",
        "Gumpa itna hong",
        "buak inla,",
        "Kote hong tawh kuang in."
      ]
    }
  ]
}