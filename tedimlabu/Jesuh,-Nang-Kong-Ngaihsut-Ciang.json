{
  "title": "Jesuh, Nang Kong Ngaihsut Ciang",
  "key": "Key: A",
  "ZBC": "ZBC: 101",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Jesuh a kici min sangin,",
        "Min ngaih zaw om lopi;",
        "Vantung leitung ahi zongin,",
        "Kimu zo",
        "ngei lo hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Dahna thuakte’ kihehnepna,",
        "Lung niamkhiatte nuamna;",
        "Thungen a zong mite",
        "ading,",
        "Itna lian bel hita."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Kam tawh a kigenkhia theilo,",
        "Thupha a ngah uh hi;",
        "A kisim khin zolo itna,",
        "Topa Jesuh",
        "thu hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Topa Jesuh nangmah simloh,",
        "Nuamna dang om nawn lo;",
        "Tu le nung iang a",
        "tawntungin,",
        "Komau phat ding om in."
      ]
    }
  ]
}
