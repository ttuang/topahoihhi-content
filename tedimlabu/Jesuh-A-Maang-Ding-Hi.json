{
  "title": "JESUH A MAANG DING HI",
  "key": "Key: E",
  "ZBC": "ZBC: 403",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Ni a taan na mun khempeuh ah,",
        "Topa Jesuh A maang ding hi;",
        "Lei mong khat pan mong khat",
        "dong-ah,",
        "Ama gam in a zai ding hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Minam kim leh pau nam kim in,",
        "Hong itna la in",
        "sa uh hi;",
        "Naupangte in Amah phat in,",
        "Ama min a thang sak ding hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Ama tungah thu",
        "kingen in,",
        "Amah kiphat tawntung ding hi;",
        "Zing meihal paknamtui bang in,",
        "Ama’ min a",
        "kizeel ding hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Tua ciang minam khempeuhte in,",
        "Ei kumpipa phat ding uh",
        "hi;",
        "Vantung mite’n la hong sa in,",
        "Lei mi’n “Amen” ci’n dawng ding",
        "hi."
      ]
    }
  ]
}