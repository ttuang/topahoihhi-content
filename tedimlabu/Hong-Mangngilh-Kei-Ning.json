{
  "title": "Hong Mangngilh Kei Ning",
  "key": "Key: Ab",
  "ZBC": "ZBC: 287",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "“Hong mangngilh kei ning”",
        "Cih thuciam muan huai hi",
        "Bangmah in kei hong susia",
        "zolo ding hi",
        "Sihna limkuam sung",
        "Zan khua a mial zong in",
        "Tua sihna kuam gal ah",
        "Ni",
        "tangtawn tung hi"
      ]
    },
    {
      "type": "chorus",
      "label": "Chorus",
      "lines": [
        "Hongmangngilh in (Nang hong mangngilh kei ning)",
        "Hong nusia kei",
        "ning (Hong nusia kei ning)",
        "Ka khut in hong len ning",
        "Ka ang ah hong pom ning;",
        "Hongmangngilh in",
        "(Nang hong mangngilh kei ning)",
        "Hong nusia kei ning (Hong nusia kei ning)",
        "Nang hong Tanpa ka hi,",
        "Kong kem den ding hi"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Jesuh hong it na le hong cin hong kep na",
        "Ka lungdam na",
        "A",
        "ma’ kiang bang ci lah ding",
        "Midang te tung gen ning",
        "A ma hong tat na",
        "A thuciam te muang",
        "in",
        "A zuih theih na ding"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "“Hong mangngilh kei ning”",
        "Cih thuciam na",
        "muang in",
        "Lungdam na la sa in",
        "Mainawt in pai ning",
        "Lawm te’n hong tai san",
        "Mi’n",
        "hong simmawh zong in",
        "Jesu’n hong ompih ding",
        "Hong lungdam sak ding"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Kham",
        "kongpi kiang ah",
        "Kei ka din’ ni ciang inKa thuakna,",
        "Ka dahna khempeuh veng ta",
        "ding",
        "“Pha hi” a diktat nasempa hong lut in",
        "Hong cih ka zak ciang in",
        "Angtang mah",
        "si ning"
      ]
    }
  ]
}