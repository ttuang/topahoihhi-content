{
  "title": "Huihpi Nakpi’n Anun Simin",
  "key": "Key: C",
  "ZBC": "ZBC: 210",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Huihpi nakpi’n a nun simin,",
        "Dahna tui bang a khan simin;",
        "Zuat ding tawldam huai,",
        "lungmuan huai;",
        "Mun om, hehpihna tokhom nuai."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Eite i lu tungah",
        "Jesuh’n,",
        "Lungdam sathau hong nilhna mun;",
        "Mundang teng sang nuam pen mun om,",
        "Sisan baang",
        "hehpihna tokhom."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Kha le khat lungsim kigawmna,",
        "Lawm le gual tawh kikholh",
        "theihna;",
        "Kikhen hang pum khat bang hong suah,",
        "Hehpihna tokhom kiim",
        "kituah."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Pumpi’ utna le mawhnate’n,",
        "Hong nawngkaisakzo nawn lo",
        "ding;",
        "Vantung in hong dawntuah sukta,",
        "Vangtang in tua tokhom tuam ta."
      ]
    }
  ]
}