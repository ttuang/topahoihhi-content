      "label": "Verse 1",
      "lines": [
        "(Lawm aw nong zui diam tua gamah)3",
        "Keipai ning,",
        "(Lawmaw nongzuidiam tua gamah)2",
        "Tua gam ah tua gam ah keipai ning.",
        "*Bawngnawi leh khuaizuluang tua gamah,",
        "*Itna bek omhi tua gamah,",
        "*Zeisu kamu dingtuagam ah,",
        "*Tua gamin vantung hilo maw."
      ]
    }
  ]
