{
  "title": "HONG NAISAK IN",
  "key": "Key: Ab",
  "ZBC": "ZBC: 361",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Nang aa hi’ng Topa,",
        "Na aw za zo ing,",
        "Kei nong itna hong gen in;",
        "Ahih hang upna",
        "tawh hong kahto ing,",
        "Kong kinaizaw lai nuam hi."
      ]
    },
    {
      "type": "chorus",
      "label": "Chorus",
      "lines": [
        "Hong naisak in Thupha Topa",
        "aw,",
        "Na sihna Singlamteh tawh,",
        "Hong kai in na kiangah thupha Topa aw,",
        "Naitakin Na pang si",
        "tawh."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Hong siangtho sak in,",
        "Hehpihna vang tawh,",
        "Na nasem ding hong zang",
        "in;",
        "Lungkia ngeilo in lametna kip tawh,",
        "Nang deih bang hong deihsak in"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Na tokhom",
        "mai-ah,",
        "Tawl khat sung bekmah,",
        "Thungenin kong khukdin zong",
        "Lawmta bangin lungsim kumkhawm in",
        "ah,",
        "Ka lung hong nuam mahmah khong."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Gun gal kah bang sihna gal kai mateng,",
        "Itna",
        "thu phawkkhin zo lo;",
        "Nangmah tawh nuamtak",
        "kong khawlkhawm mateng,",
        "Nuamna sang kiban nailo."
      ]
    }
  ]
}