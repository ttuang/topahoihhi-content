{
  "title": "DAWN UN JESUH’ MIN VANGLIATNA",
  "key": "Key: G",
  "ZBC": "ZBC: 149(B)",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Dawn un Jesuh’ min vangliatna,",
        "Vantung mite bok un,",
        "Vantung mite bok un;",
        "Kumpi",
        "Lukhu hong la un la,"
      ]
    },
    {
      "type": "chorus",
      "label": "Chorus",
      "lines": [
        "Kumpi lian Kumpi, Kumpi, Kumpi",
        "Kumpi lian bel pia",
        "un"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Pasian biakman thahna thuakte’n,",
        "Amah kumpi pia un,",
        "Amah kumpi pia",
        "un,",
        "Jessi suan in phatna ngah hen,"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Teeltuam Israel minamte aw,",
        "Tawmkha na hih",
        "hang un,",
        "Tawmkha na hih hang un,",
        "Hong tan zo hi, hehpihna tawh,"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Zentail",
        "mikhialte’n zong dan pan,",
        "Hong hot mangngilh kei un,",
        "Hong hot mangngailh kei un;",
        "Min",
        "phatna a khe ah va nga’n"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 5",
      "lines": [
        "Hih leitung a minam kim in,",
        "Jesuh lian bel sak",
        "un,",
        "Jesuh lian bel sak un;",
        "Liatna khempeuh ama aa ci’n"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 6",
      "lines": [
        "Ama mi siang",
        "honpite tawh,",
        "A khe mai-ah bok un,",
        "A khe mai-ah bok un;",
        "Phat khawm tawntung ni amau tawh,"
      ]
    }
  ]
}