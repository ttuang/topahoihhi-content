{
  "title": "Hong Pai Un A Umte!",
  "key": "Key: G",
  "ZBC": "ZBC: 336",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Honpa kiang pan na zaksa thu,",
        "Ngai dih in, lungdamna thu;",
        "Hong sapna dawng lo ding na",
        "hiam?",
        "Topa’ lam na kihei diam?"
      ]
    },
    {
      "type": "chorus",
      "label": "Chorus",
      "lines": [
        "A umte’n zuan, a umte’n",
        "zuan,",
        "Jesuh zuanin hing ta un;",
        "A umte’n zuan, a umte’n zuan,",
        "Jesuh zuanin hingta",
        "un!"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Hun tampi na beisak zo a,",
        "Anlak phatna mu zo a;",
        "Phalbi vukte tui khin",
        "napi,",
        "Mawhna sung na buallai hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Na deih teel hun Jesuh’n ngak hi,",
        "Na",
        "khentat mengmeng ding hi;",
        "Kha Siangtho in hong zol lai-in,",
        "Honpa zuan in beelta",
        "in."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Na lungsim Pasian kiang pia in,",
        "Khazih tatna si muang in;",
        "Vantung a om Jesuh",
        "en in!",
        "A kammal kip hi, muang in!"
      ]
    }
  ]
}