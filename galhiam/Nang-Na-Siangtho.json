{
  "title": "NANG NA SIANG THO HI",
  "key": "Key: E",
  "galHiam": "Gal Hiam: 234",
  "ZBC": null,
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Nang na siangtho, siang tho",
        "Nang bang om kei Topa",
        "Nang na siangtho siangtho",
        "Naminthang den ta hen.",
        "Minphat nala ka sa sa ding",
        "Kong it zaw semsem ding",
        "Kumpi tokhom tawh kinai na mun ah",
        "Ka om na'ng ka mu hi."
      ]
    }
  ]
}