{
  "title": "Vantung Mite’ Lasakna",
  "key": "Key: F",
  "ZBC": "ZBC: 091",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Vantung mite lasakna",
        "Zanglei tung ah kiza hi",
        "Mual sang ten zong sangsawn a",
        "Lungdamna",
        "la kithawn hi",
        "Cho.",
        "Thang………………..ta hen",
        "Pasian",
        "minthan ta hen",
        "Thang………………….ta hen",
        "Van a sangbel",
        "Pasian"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Tuucingte no lungdamna",
        "Nuamna late bang thu hiam",
        "Vantung la ngaih no",
        "sakna",
        "Lungdamna thu banghang hiam"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Betlen khua ah hong pai in",
        "Noten zong hong en",
        "ve un",
        "Khazih Kumpi khukdin in",
        "Noten zong hong phatpih un"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Vantung min a phat",
        "laitak",
        "Gankuang sung kisial en un",
        "Phatna kote sak laitak",
        "Josef, Mary hong huh un"
      ]
    }
  ]
}