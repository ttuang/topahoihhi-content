{
  "title": "HONG HONPA NA SIH DONG",
  "key": "Key: G",
  "ZBC": "ZBC: 362",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Hong Honpa, Na sih dong,",
        "Kei Nong it zo;",
        "Nang a’ding na khat zong,",
        "Ka hong it",
        "lo,",
        "Itna tawh hong kun ning,",
        "Ka ciamna tang tun ning,",
        "Nang kiang tu’n hong tun",
        "ning,",
        "Na khat teitei."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Hehpih tokhom mai-ah, hehpih kong ngen;",
        "Upna neihsun in",
        "ah, Jesuh kong en;",
        "Thuak ding, gen ding, sak ding,",
        "Na khat peuh Nang a’ ding,",
        "Kei hong",
        "hih zo sak in,",
        "Na khat teitei."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Lungsim man hong pia in,",
        "Nang ma aa bang;",
        "A",
        "ni kipeel lo-in,",
        "Ka hih theih na’ng.",
        "It na tawh na sepna,",
        "Khat peuh tung migit",
        "na,",
        "Lamkhial khat ngah zawh na’ng,",
        "Na khat teitei."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Keimah le ka",
        "neihsa,",
        "Nong piak sa hi’ng;",
        "Hih lai ka nuntakna,",
        "Nang ma a’ ding.",
        "Na mai",
        "kong muh ciangin,",
        "Tatkhiat sa ka kha-in,",
        "Hi hen, Nang a’ dingin,",
        "Na khat teitei."
      ]
    }
  ]
}