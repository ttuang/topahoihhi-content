{
  "title": "INNKUAN KI-IT LENG",
  "key": "Key: Ab",
  "ZBC": "ZBC: 400",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "I kimkot teng kilawmna, Innkuan ki-it leng",
        "Awging khempeuh lungdamna",
        "Innkuan ki-it",
        "leng",
        "Lungnopna leh kicinna",
        "Kiheina teng maitaina",
        "Hun khempeuh nuammahmah a",
        "Innkuan ki-it",
        "leng",
        "Innkuan sung ki-it leng",
        "Hun khempeuh nuam mahmah a",
        "Innkuan ki-it",
        "leng."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Bukno khat sung zong nuamna",
        "Innkuan ki-it leng",
        "Huatna en na",
        "omlohna",
        "Innkuan ki-it leng",
        "I paina teng ah nuamna",
        "Leitung khempeuh lungdamna",
        "Lungdamna",
        "dim nuntakna",
        "Innkuan ki-it leng",
        "Innkuan sung ki-it leng",
        "Lungdamna dim nuntakna",
        "Innkuan",
        "ki-it leng."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Pasian zong hong lungdampih",
        "Innkuan ki-it leng",
        "Leitung teng ki-itna",
        "dim",
        "Innkuan ki-it leng",
        "Luiging bek zong la ngaihpi",
        "Vandum bek zong",
        "maitaina",
        "Pasian’ van pan hong nuihpih",
        "Innkuan ki-it leng",
        "Innkuan sung ki-it",
        "leng",
        "Pasian’ vanpan hong nuihpih",
        "Innkuan ki-it leng."
      ]
    }
  ]
}