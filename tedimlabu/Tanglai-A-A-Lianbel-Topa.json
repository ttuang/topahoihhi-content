{
  "title": "TANGLAI-A A LIANBEL TOPA",
  "key": "Key: C",
  "ZBC": "ZBC: 047",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Tanglai a a lianbel Topa,",
        "Nungcianga lawpna hi;",
        "Tui kilok ciang na omna sung,",
        "Hehpih",
        "in hong liah hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Topa Pasian tokhom kiimah,",
        "Mi siangthote’n nuamsa;",
        "Na",
        "khut tawh Na liahna, kepna,",
        "Bit bel ding hi Topa."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Mual le guamte a kikhunma,",
        "Lei",
        "pumpi pian ma-in;",
        "Tawntung Pasian na hi khina,",
        "Kip den ding kumkhua-in."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Kum tul",
        "kum then Topa mai-ah,",
        "Nitak om ngeilo hi;",
        "Khuamilna in a leeng mang a,",
        "Zingsang khuavak bang",
        "hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 5",
      "lines": [
        "Tuikhu bangin na bei thei hi,",
        "Manglangin tawp thei hi;",
        "Zan nitak, zingsang",
        "ciang mang hi,",
        "I mang tawh kibang hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 6",
      "lines": [
        "Tanglai-a a lian bel Topa,",
        "Nung ciang a",
        "lawpna hi;",
        "Gimna tuak ciang hong kempha in,",
        "Na in ah hong kha in."
      ]
    }
  ]
}