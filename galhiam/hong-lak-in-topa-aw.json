{
  "title": "HONG LAK IN TOPA AW",
  "key": "",
  "galHiam": "Gal Hiam: 44",
  "ZBC": null,
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Hong lak in Topa aw",
        "Singlamteh thu teltak in",
        "Nazaret Jesu itna hong dim in",
        "Ka kamtawh hong phat ning",
        "A tawntung la hong sa ning",
        "Ka nunna ka deihna Nang aa hitang"
      ]
    }
  ]
}