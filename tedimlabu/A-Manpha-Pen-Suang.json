{
  "title": "A Manpha Pen Suang",
  "key": "Key: G",
  "ZBC": "ZBC: 155",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "A manpha pen suang ke’n mu ing,",
        "Lungdamin la ka sa;",
        "Jesuh kei aa ci’n la sa",
        "ning,",
        "Khazih la-in sa ning."
      ]
    },
    {
      "type": "chorus",
      "label": "Chorus",
      "lines": [
        "A manpha pen suang ke’n mu ing,",
        "Lungdamin",
        "la ka sa;",
        "Jesuh kei aa ci’n la sa ning!",
        "Khazih la-in sa ning"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Jesuh Siampi",
        "ka Kumpi hi,",
        "Khuavak Kamsangpa hi;",
        "Tokhom mai-ah Kamsanglian pa,",
        "Ka van Kumpipa",
        "hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Amah topa-te’ Topa hi,",
        "Kumpite’ Kumpi hi;",
        "Amah in thumanna Ni",
        "hi,",
        "A kha nuai cidamna."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Kilemna ding kei taang hong si,",
        "Kei tang A si hong",
        "bua;",
        "A lamdang kei hong gum Pa hi,",
        "Amah mahin hong gum."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 5",
      "lines": [
        "Khazih ah deihna teng",
        "cinga,",
        "Ka lungmuanna ahi;",
        "Leitung hinna Amah hi-a,",
        "Vantung hinna zong hi."
      ]
    }
  ]
}