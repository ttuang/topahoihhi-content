{
  "title": "Tuucingte’n Tuute Acin Laitak",
  "key": "Key: G",
  "ZBC": "ZBC: 090",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Tuucing te lau-in vantung mi’n",
        "Laukei un thuphapi",
        "Note le leitng mi a",
        "ding",
        "Tu-in kong paipih hi"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "David khua Betlen khuapi sung",
        "Hong gumding in Khazih",
        "David suan mihing pawl sung",
        "pan",
        "Tu ni-in hong suak hi"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Bawngkuang sung puantawh kitun a",
        "Naupang in a om hi",
        "No tu in pai un zong un la",
        "No na",
        "mu ding uh hi"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Vantung min a cihlaitak in",
        "Van mite hong pai a",
        "Pasian vanglian mah mah ci in",
        "Sa uh hi",
        "phatna la"
      ]
    },
    {
      "type": "verse",
      "label": "Verse 5",
      "lines": [
        "Van ah Pasian min lian henla",
        "Leitung nopna omhen",
        "Honghehpihna le hong itna",
        "Mitung om",
        "tawntung hen"
      ]
    }
  ]
}
