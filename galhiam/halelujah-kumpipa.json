    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Haleluijah Kumpipa minthang hen",
        "Haleluijah Pasian Tuuno aw",
        "Phat ding in Na ki lawm",
        "Ka lungsim khempeuh tawh",
        "Haleluijah Pasian Tuuno aw"
      ]
    }
  ]
