{
  "title": "TOPA AW, KEI HONG MANGNGILH KEI IN",
  "key": "Key: F",
  "galHiam": "Gal Hiam: 332",
  "ZBC": null,
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Kei hong Honpa Asi luangin,",
        "Ka Kumpi hong si maw.",
        "Tangtel bang bek keimah ading,",
        "A lutang hong zang maw."
      ]
    },
    {
      "type": "chorus",
      "label": "Chorus",
      "lines": [
        "Nang tung kong thumaan zawh na'ngin,",
        "Topa kei hong huh in.",
        "Kumpi tokhom Na luah ciangin,",
        "Kei hong mangngilh kei in."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Keima gitlohnate hangin,",
        "Singlamteh tung tau maw.",
        "Lamdang hehpihna le itna,",
        "Bang tawh teh thei ding maw."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Ama piansak mi mawhna hang,",
        "A piangsakpa Khazih.",
        "Hong sih laitak,",
        "khuamial sungah,",
        "Ni a buk mah ding hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Kei zong singlamteh ka muh ciang,",
        "Zumin ka kiseel diam.",
        "Lungdamna tawh lung nehno-in,",
        "Ka khi ka luang sak diam."
      ]
    }
  ]
}