{
  "title": "LAM HONG HILH IN, TUNG PASIAN AW",
  "key": "Key: D",
  "ZBC": "ZBC: 024",
  "sections": [
    {
      "type": "verse",
      "label": "Verse 1",
      "lines": [
        "Lam hong hilh in tung Pasian aw,",
        "Keu gaw gam khualzin lai-in",
        "Ka thanem hang, Nang Na",
        "thahat,",
        "Na khut tawh hong len den in",
        "Van khomun aw, Van khomun aw,",
        "Ka kham mateng hong vak",
        "aw,",
        "Ka kham mateng hong vak aw."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 2",
      "lines": [
        "Damna tui a hong luan khiatna,",
        "Limlang tuinak",
        "hong hon in;",
        "Sunin meikhuam zanin meikhuam,",
        "Lam tawntung hong khasak in",
        "Hong Honpa aw, Hong",
        "Honpa aw,",
        "Ka lum ka tei hong hi aw,",
        "Ka lum ka tei hong hi aw."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 3",
      "lines": [
        "Jordan gun gei ka",
        "din ciangin,",
        "Patauh launa beisak in;",
        "Tuihualpi hong kantanpih in,",
        "Kanaan gam hong lutpih",
        "in.",
        "Phatna late, phatna late,",
        "Kong sak tawntung ding uh hi,",
        "Kong sak tawntung ding uh",
        "hi."
      ]
    },
    {
      "type": "verse",
      "label": "Verse 4",
      "lines": [
        "Lungkham dahna le lungzinna,",
        "Launa zumna teng beita;",
        "Honpa’ makaihna",
        "muang peuh leng,",
        "Lungkhamna khempeuh beita.",
        "Phatna late, phatna late,",
        "Kong sak tawntung ding",
        "uh hi.",
        "Kong sak tawntung ding uh hi."
      ]
    }
  ]
}